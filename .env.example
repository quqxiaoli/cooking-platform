# .env.example — cooking-platform
# Copy this file to .env and fill in real values.
#   cp .env.example .env
# .env is listed in .gitignore and must NEVER be committed.

# ── Config file path ──────────────────────────────────────────────────────────
# Defaults to configs/config.yaml when not set.
CONFIG_PATH=configs/config.yaml

# ── MySQL (dev: matches docker-compose.yml defaults) ─────────────────────────
MYSQL_ROOT_PASSWORD=cooking123
MYSQL_DATABASE=cooking_platform

# ── Redis (dev: no password) ──────────────────────────────────────────────────
# REDIS_PASSWORD=          # leave empty for dev; required in prod

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars

# ── AES encryption key (for phone number storage — Step 11) ──────────────────
# Must be exactly 32 bytes for AES-256-GCM. Generate with: openssl rand -hex 16
# AES_KEY=                  # not required until Step 11

# ── Aliyun OSS (not required until Step 9) ────────────────────────────────────
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=
# OSS_ENDPOINT=
# OSS_REGION=

# ── Aliyun SMS (not required until Step 3 — prod) ─────────────────────────────
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# ── Aliyun Content Security (not required until Step 10) ──────────────────────
# AUDIT_ACCESS_KEY_ID=
# AUDIT_ACCESS_KEY_SECRET=

# ── RabbitMQ (not required until Step 13 — EventBus switch) ──────────────────
# RABBITMQ_USER=cooking
# RABBITMQ_PASSWORD=

# ── golang-migrate (used by make migrate-up / migrate-down) ──────────────────
MIGRATE_DSN=mysql://root:cooking123@tcp(127.0.0.1:3306)/cooking_platform
