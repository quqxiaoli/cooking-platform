# .env.prod.example — Production secrets for docker-compose.prod.yml
#
# Copy to `.env.prod` and replace every <PLACEHOLDER>:
#   cp .env.prod.example .env.prod
#   # edit .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# `.env.prod` is in .gitignore — NEVER commit it.
#
# Every ${VAR:?...} line in docker-compose.prod.yml refuses to start if the
# corresponding variable is empty.  If `docker compose up` complains about a
# missing variable, set it here and retry — do not work around with a
# default value at the compose layer.

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=<replace-with-strong-random-string>
MYSQL_DATABASE=cooking_platform

# Replication user (used by mysql-slave-init to point the slave at master).
REPL_USER=repl
REPL_PASSWORD=<replace-with-strong-random-string>

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required in prod.  Generate with: openssl rand -base64 32
REDIS_PASSWORD=<replace-with-strong-random-string>

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=cooking
RABBITMQ_PASSWORD=<replace-with-strong-random-string>

# ── App: AES-256-GCM phone encryption (Step 11) ───────────────────────────────
# Exactly 64 hex characters (= 32 bytes).  Generate: openssl rand -hex 32
APP_ENCRYPTION_PHONE_KEY=<replace-64-hex-chars>
# Pepper for SHA-256 phone hash.  Any opaque random string.
APP_ENCRYPTION_PHONE_PEPPER=<replace-with-strong-random-string>

# ── App: JWT ──────────────────────────────────────────────────────────────────
# Minimum 32 characters.  Generate: openssl rand -hex 32
APP_JWT_SECRET=<replace-min-32-chars>

# ── App: database DSN ────────────────────────────────────────────────────────
# Points the app at the prod MySQL master container.  Username MUST NOT be
# root in real deployments — create a least-privilege user (CREATE, SELECT,
# INSERT, UPDATE, DELETE on cooking_platform.* only) and use that here.
APP_DATABASE_DSN=cooking:<DB_PASSWORD>@tcp(mysql:3306)/cooking_platform?charset=utf8mb4&parseTime=True&loc=Local&timeout=5s

# ── App: RabbitMQ URL ────────────────────────────────────────────────────────
APP_MQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/

# ── App: Aliyun OSS ──────────────────────────────────────────────────────────
APP_OSS_ACCESS_KEY_ID=<aliyun-oss-AK>
APP_OSS_ACCESS_KEY_SECRET=<aliyun-oss-SK>

# ── App: Aliyun SMS ──────────────────────────────────────────────────────────
APP_SMS_ACCESS_KEY_ID=<aliyun-sms-AK>
APP_SMS_ACCESS_KEY_SECRET=<aliyun-sms-SK>

# ── App: Aliyun Content Security (Green) ─────────────────────────────────────
# Use a dedicated RAM sub-account with Green-read-only permissions.
APP_AUDIT_ACCESS_KEY_ID=<aliyun-green-AK>
APP_AUDIT_ACCESS_KEY_SECRET=<aliyun-green-SK>

# ── Grafana ──────────────────────────────────────────────────────────────────
# Required.  Used to log into Grafana via the SSH tunnel to 127.0.0.1:3000.
APP_GRAFANA_ADMIN_PASSWORD=<replace-with-strong-random-string>

# ── Alertmanager ([Fix #6]) ──────────────────────────────────────────────────
# SMTP relay for ops alerts.  Aliyun DirectMail / SendGrid / company SMTP all
# work — just point smarthost at host:port and provide auth credentials.
ALERT_SMTP_SMARTHOST=smtpdm.aliyun.com:465
ALERT_SMTP_FROM=alerts@<your-domain>
ALERT_SMTP_USERNAME=<smtp-user>
ALERT_SMTP_PASSWORD=<smtp-password>
ALERT_EMAIL_TO=<ops-email-address>
