# ── Secrets (never commit) ────────────────────────────────────────────────────
# Match any .env* variant (.env, .env.prod, .env.local, ...) and re-allow
# the committed *.example templates below so dev onboarding still works.
.env*
!.env.example
!.env.prod.example
*.pem
*.key
*.p12
*.pfx
# Plaintext secret backup used to rebuild .env.prod after server wipe.
docs/prod.md
docs/ops/prod.md

# ── Build artefacts ───────────────────────────────────────────────────────────
bin/
/server
/migrate-phone
*.exe
*.exe~
*.dll
*.so
*.dylib

# ── Test & coverage ───────────────────────────────────────────────────────────
*.test
coverage.out
coverage.html

# ── Go module cache (managed by go toolchain, not the repo) ──────────────────
vendor/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
# Local overrides — do not commit per-developer docker-compose tweaks
docker-compose.override.yml

# ── Certificates (generated locally, not checked in) ─────────────────────────
deploy/nginx/certs/

# ── Temporary / scratch files ─────────────────────────────────────────────────
tmp/
scratch/

# ── Bare-name SSH keys (paranoid mode) ────────────────────────────────────────
id_rsa
id_ed25519
id_ecdsa
*_rsa
*_ed25519
*_ecdsa

# ── Script backups (sed -i.bak / vim ~) ───────────────────────────────────────
*.bak
*~

# ── Obsidian workspace config ─────────────────────────────────────────────────
.obsidian/

# ── Claude Code 本机设置（不入仓库） ─────────────────────────────────────────
.claude/

