# ── Secrets (never commit) ────────────────────────────────────────────────────
.env
*.pem
*.key
*.p12
*.pfx

# ── Build artefacts ───────────────────────────────────────────────────────────
bin/
/server
/migrate-phone
*.exe
*.exe~
*.dll
*.so
*.dylib

# ── Test & coverage ───────────────────────────────────────────────────────────
*.test
coverage.out
coverage.html

# ── Go module cache (managed by go toolchain, not the repo) ──────────────────
vendor/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
# Local overrides — do not commit per-developer docker-compose tweaks
docker-compose.override.yml

# ── Certificates (generated locally, not checked in) ─────────────────────────
deploy/nginx/certs/

# ── Temporary / scratch files ─────────────────────────────────────────────────
tmp/
scratch/

# ── Bare-name SSH keys (paranoid mode) ────────────────────────────────────────
id_rsa
id_ed25519
id_ecdsa
*_rsa
*_ed25519
*_ecdsa

# ── Script backups (sed -i.bak / vim ~) ───────────────────────────────────────
*.bak
*~

# ── Obsidian workspace config ─────────────────────────────────────────────────
.obsidian/