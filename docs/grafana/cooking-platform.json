{
  "id": null,
  "uid": "cooking-platform",
  "title": "Cooking Platform",
  "tags": ["cooking", "go"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cooking_http_requests_total[1m])) by (handler, method, status)",
          "legendFormat": "{{method}} {{handler}} {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 2,
      "title": "HTTP Latency P50 / P95 / P99 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(cooking_http_request_duration_seconds_bucket[1m])) by (le, handler)) * 1000",
          "legendFormat": "P50 {{handler}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(cooking_http_request_duration_seconds_bucket[1m])) by (le, handler)) * 1000",
          "legendFormat": "P95 {{handler}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(cooking_http_request_duration_seconds_bucket[1m])) by (le, handler)) * 1000",
          "legendFormat": "P99 {{handler}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 3,
      "title": "Consumer Processed Rate (events/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cooking_consumer_processed_total[1m])) by (consumer, topic)",
          "legendFormat": "{{consumer}} / {{topic}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 4,
      "title": "Consumer Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cooking_consumer_queue_depth",
          "legendFormat": "{{consumer}} ({{instance}})",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 5,
      "title": "Redis Command Latency P95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(cooking_redis_command_duration_seconds_bucket[1m])) by (le, command)) * 1000",
          "legendFormat": "P95 {{command}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 6,
      "title": "MySQL Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cooking_mysql_pool_open_connections",
          "legendFormat": "open ({{instance}})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cooking_mysql_pool_inuse_connections",
          "legendFormat": "in-use ({{instance}})",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cooking_mysql_pool_idle_connections",
          "legendFormat": "idle ({{instance}})",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    }
  ]
}
